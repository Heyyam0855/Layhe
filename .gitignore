*.sln
*.sw?
*.code-workspace

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
venv/
env/
.env
.venv/
pip-log.txt
pip-delete-this-directory.txt
