*.spec

# ---------- Node.js / JavaScript ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
.yarn-integrity

# ---------- Java ----------
*.class
*.jar
*.war
*.ear
*.log
target/
.gradle/
build/
out/
.classpath
.project
.settings/

# ---------- C / C++ / Assembly ----------
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.out
*.a
*.lib
*.bin
*.lst

# ---------- SQL ----------
*.sqlite
*.sqlite3
*.db

# ---------- Flask / Django ----------
instance/
*.pyc
*.pyo
migrations/

# ---------- Logs & Temp ----------
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.cache

# ---------- Environment / Secrets ----------
.env
.env.local
.env.production
*.pem
*.key
secrets/
